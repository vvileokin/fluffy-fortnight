# Copy to .env.local and fill in. Never commit real secrets.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Public site URL (prod: https://cs2ua.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Telegram login
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Optional: Supabase service role (server only) — needed later for Telegram
# session linking and admin writes. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=
